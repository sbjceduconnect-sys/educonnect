<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GROUP 1: BASE CONNECTIVITY (Install-time — granted automatically)  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!--
        INTERNET: Required for the Capacitor WebView to communicate with the
        EduConnect Django backend (https://educonnectsbjc.ddns.net).
        Used for all API calls: authentication, dashboard data, attendance
        syncing, exam grades, and announcement fetching.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        ACCESS_NETWORK_STATE: Allows the app to inspect connectivity status
        before initiating expensive operations such as downloading PDF progress
        reports or submitting attendance/exam records, preventing silent failures.
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GROUP 2: ATTENDANCE MODULE — CAMERA (Dangerous / Runtime request)  -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!--
        CAMERA: Dangerous permission — must be requested at runtime via
        @capacitor/camera plugin. Used exclusively in the Teacher Attendance
        Marker screen when the "Scan QR Code" flow is triggered. The permission
        prompt is gated behind a rationale dialog before invocation.
        android:required="false" keeps the app installable on devices without
        a camera (e.g. some tablets), avoiding Play Store filtering.
    -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GROUP 3: FILE SYSTEM & DOCUMENT MANAGEMENT (Version-specific)      -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!--
        READ_EXTERNAL_STORAGE (API ≤ 32): Dangerous permission — runtime request.
        Required on Android 12 and below to allow teachers and students to pick
        files from device storage when uploading study materials to the platform.
        On API 33+, this is superseded by READ_MEDIA_* permissions below.
    -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!--
        WRITE_EXTERNAL_STORAGE (API ≤ 28): Dangerous permission — runtime request.
        Required on Android 9 and below to save downloaded PDF progress reports
        to the device's public Downloads folder. On API 29+ (Android 10+), the
        app uses Scoped Storage via MediaStore / Capacitor Filesystem API, making
        this broad write permission unnecessary.
    -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!--
        READ_MEDIA_IMAGES / READ_MEDIA_VIDEO (API 33+ / Android 13+):
        Granular replacements for READ_EXTERNAL_STORAGE on Android 13+.
        Required if study materials include images (thumbnails, infographics)
        or video lecture files that teachers upload to the platform.
        These are Dangerous permissions requested at runtime via
        the @capacitor/filesystem plugin only when the upload flow is triggered.
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GROUP 4: ANNOUNCEMENTS & COMMUNICATION HUB (Notifications)         -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!--
        POST_NOTIFICATIONS (API 33+ / Android 13+): Dangerous permission —
        runtime request. Required to push instant broadcast notifications for
        critical academic updates: schedule changes, new announcements from
        teachers, upcoming exam reminders, and grade publication alerts.
        On API ≤ 32, notifications are granted automatically without this
        declaration. The runtime request is performed on first app launch.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

</manifest>
